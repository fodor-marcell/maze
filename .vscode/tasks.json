{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: build maze project",
            "command": "gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/src/maze.c",
                "${workspaceFolder}/src/gate.c",
                "${workspaceFolder}/src/render.c",
                "${workspaceFolder}/src/glshader.c",
                "${workspaceFolder}/src/maze_generator.c",
                "${workspaceFolder}/third_party/soil/SOIL/SOIL.c",
                "${workspaceFolder}/third_party/soil/SOIL/image_DXT.c",
                "${workspaceFolder}/third_party/soil/SOIL/image_helper.c",
                "${workspaceFolder}/third_party/soil/SOIL/stb_image_aug.c",
                "-DGL_CLAMP_TO_EDGE=0x812F",
                "-I${workspaceFolder}/include",
                "-I${workspaceFolder}/third_party/freeglut/include",
                "-I${workspaceFolder}/third_party/soil",
                "-L${workspaceFolder}/third_party/freeglut/lib",
                "-lfreeglut",
                "-lopengl32",
                "-lglu32",
                "-lwinmm",
                "-o",
                "${workspaceFolder}/maze.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "${workspaceFolder}/third_party/freeglut/bin;${env:PATH}"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}